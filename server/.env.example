# Supabase — project URL and service-role key (bypasses RLS, server-side only)
# Get both from: https://supabase.com/dashboard → project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Agent signer private key (for POST /execute co-signing)
# Generate a private key for your agent and use the signer address on client .env
AGENT_PRIVATE_KEY=

# Get your Pimlico bundler and paymaster API key from https://dashboard.pimlico.io
PIMLICO_API_KEY=

# Zerion API key (for portfolio / token balances on BNB Chain). Get one at https://zerion.io
ZERION_API_KEY=

# Telegram bot token (for REVIEW/BLOCK notifications)
TELEGRAM_BOT_TOKEN=

# Server port
PORT=3001

# CORS origin (optional; defaults to allow all)
CORS_ORIGIN=
